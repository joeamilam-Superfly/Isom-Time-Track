# Copy this file's contents into Netlify's environment variables UI
# (Project configuration > Environment variables), or use:
#   netlify env:import .env
# Do NOT commit a real .env file with actual secrets to git.

# Supabase project (Settings > API in the Supabase dashboard)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Used to sign the login session token. Generate a long random string,
# e.g. run:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_TOKEN_SECRET=replace_with_a_long_random_string

# Twilio (leave unset until ready - reminders will log to function output
# instead of sending real texts when these are missing)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Anthropic API key, for the in-app AI help assistant (the chat-bubble
# button in the header). Get one at https://console.anthropic.com -
# Settings > API Keys. Leave unset and the assistant button will show a
# friendly "not configured yet" message instead of failing silently.
ANTHROPIC_API_KEY=
